{
  "name": "@maxmilton/solid-router",
  "version": "0.3.2",
  "type": "module",
  "description": "A lightweight History API based router for Solid",
  "repository": "maxmilton/solid-router",
  "author": "Max Milton <max@2okki.com>",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src"],
  "workspaces": ["test/fixtures"],
  "scripts": {
    "build": "vite build",
    "lint": "bun lint:fmt && bun lint:js && bun lint:ts",
    "lint:fmt": "biome check",
    "lint:js": "eslint",
    "lint:ts": "tsc --noEmit",
    "postbuild": "tsc --project tsconfig.d.json",
    "prebuild": "rm -rf dist",
    "pretest:e2e": "bun --cwd test/fixtures build",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "peerDependencies": {
    "solid-js": "^1.0.0"
  },
  "dependencies": {
    "qss": "^3.0.0",
    "regexparam": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@eslint/js": "10.0.1",
    "@maxmilton/eslint-config": "0.3.2",
    "@maxmilton/test-utils": "0.0.15",
    "@playwright/test": "1.61.1",
    "@solidjs/testing-library": "0.8.10",
    "@testing-library/jest-dom": "6.9.1",
    "@types/bun": "1.3.14",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/eslint-plugin": "1.6.20",
    "eslint": "10.6.0",
    "eslint-plugin-unicorn": "69.0.0",
    "jsdom": "29.1.1",
    "sirv": "3.0.2",
    "solid-js": "1.9.13",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.2",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.9"
  }
}
